# ─────────────────────────────────────────────────────────────────────
# OpenHuman API — Environment Variables
# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────

# Server
# API_HOST=0.0.0.0
# API_PORT=8000
# CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
# ENVIRONMENT=development

# Database (PostgreSQL via asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/openhuman
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# JWT authentication
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# JWT_SECRET_KEY=change-me-in-production
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=60

# Encryption key for bot tokens (AES-256-GCM, 64 hex chars)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────────────────
# OpenAI — used by the LangGraph agent
# ─────────────────────────────────────────────────────────────────────

OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=               # unset for OpenAI; set for Azure / Ollama / etc.

# ─────────────────────────────────────────────────────────────────────
# Document storage
# ─────────────────────────────────────────────────────────────────────
# UPLOAD_DIR=./uploads

# Storage backend: "local" (default, stores on disk) or "s3" (S3-compatible bucket)
# STORAGE_BACKEND=local

# S3-compatible storage (only used when STORAGE_BACKEND=s3)
# S3_ENDPOINT_URL=              # e.g. http://localhost:9000 for MinIO; leave empty for AWS
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=auto
# S3_BUCKET_NAME=openhuman-uploads
# S3_PRESIGNED_URL_EXPIRY=3600  # seconds before a presigned download URL expires

# ─────────────────────────────────────────────────────────────────────
# Slack — Fixed Named Bots
# ─────────────────────────────────────────────────────────────────────
# Identity mode: "fixed" (recommended), "shared", or "per_employee" (deprecated)
# SLACK_IDENTITY_MODE=fixed

# OAuth redirect URI for Slack install flow
# SLACK_OAUTH_REDIRECT_URI=http://localhost:8000/api/slack/oauth/callback

# Fixed bot credentials — one set per employee type.
# Each bot needs its own Slack app registered at https://api.slack.com/apps
# with Socket Mode enabled.
#
# HR — Alison (Human Resources Specialist)
# SLACK_BOT_HR_CLIENT_ID=
# SLACK_BOT_HR_CLIENT_SECRET=
# SLACK_BOT_HR_APP_TOKEN=
#
# Support — Alex (Customer Support Specialist)
# SLACK_BOT_SUPPORT_CLIENT_ID=
# SLACK_BOT_SUPPORT_CLIENT_SECRET=
# SLACK_BOT_SUPPORT_APP_TOKEN=
#
# Sales — Marcus (Sales Representative)
# SLACK_BOT_SALES_CLIENT_ID=
# SLACK_BOT_SALES_CLIENT_SECRET=
# SLACK_BOT_SALES_APP_TOKEN=
#
# General — Jordan (General Assistant)
# SLACK_BOT_GENERAL_CLIENT_ID=
# SLACK_BOT_GENERAL_CLIENT_SECRET=
# SLACK_BOT_GENERAL_APP_TOKEN=
#
# Legal & Compliance — Taylor (Legal & Compliance Officer)
# SLACK_BOT_LEGAL_CLIENT_ID=
# SLACK_BOT_LEGAL_CLIENT_SECRET=
# SLACK_BOT_LEGAL_APP_TOKEN=

# Shared mode app token (only used when SLACK_IDENTITY_MODE=shared)
# SLACK_APP_TOKEN=

# ─────────────────────────────────────────────────────────────────────
# Bot Gateway (optional — set GATEWAY_ENABLED=true for Discord / Slack)
# ─────────────────────────────────────────────────────────────────────
# GATEWAY_ENABLED=false

# ─────────────────────────────────────────────────────────────────────
# Cognee (deferred — Phase 5)
# ─────────────────────────────────────────────────────────────────────
# COGNEE_DATA_DIR=./cognee_data
