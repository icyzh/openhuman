mary": "Slack Install", "description": "Redirect the browser to Slack's OAuth authorize page.\n\nThe ``employee_id`` and ``org_id`` are baked into a signed state\nparameter so the callback can associate the token with the right\nemployee.\n\nIn **per_employee** mode the authorize URL is built from the employee's\nassigned ``SlackAppSlot`` rather than the global settings.", "operationId": "slack-slack_install", "parameters": [{"name": "employee_id", "in": "query", "required": true, "schema": {"type": "string", "description": "Employee UUID", "title": "Employee Id"}, "description": "Employee UUID"}, {"name": "org_id", "in": "query", "required": true, "schema": {"type": "string", "description": "Organization UUID", "title": "Org Id"}, "description": "Organization UUID"}, {"name": "redirect_to", "in": "query", "required": false, "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "description": "URL to redirect back to after callback", "title": "Redirect To"}, "description": "URL to redirect back to after callback"}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/slack/oauth/callback": {"get": {"tags": ["slack"], "summary": "Slack Oauth Callback", "description": "Handle the OAuth redirect from Slack.\n\n1. Validates the state JWT to recover employee / org.\n2. Exchanges the ``code`` for a bot token via Slack's API.\n3. Encrypts and stores the token on the employee record.\n4. Redirects the browser back to the employee's dashboard page.\n\nIn **per_employee** mode the exchange uses the slot's client secret\nrather than the global one, and persists workspace metadata.", "operationId": "slack-slack_oauth_callback", "parameters": [{"name": "code", "in": "query", "required": true, "schema": {"type": "string", "description": "Temporary OAuth code from Slack", "title": "Code"}, "description": "Temporary OAuth code from Slack"}, {"name": "state", "in": "query", "required": true, "schema": {"type": "string", "description": "State parameter echoed back by Slack", "title": "State"}, "description": "State parameter echoed back by Slack"}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/organizations/{org_id}/mcp-connectors": {"get": {"tags": ["mcp"], "summary": "List Mcp Connectors", "description": "Return every connector in the registry with its connection count\nfor this organization.", "operationId": "mcp-list_mcp_connectors", "security": [{"HTTPBearer": []}], "parameters": [{"name": "org_id", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid", "title": "Org Id"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/ConnectorStatus"}, "title": "Response Mcp-List Mcp Connectors"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/organizations/{org_id}/employees/{emp_id}/mcp-connections": {"get": {"tags": ["mcp"], "summary": "List Employee Mcp Connections", "description": "List MCP connections available to *emp_id* (theirs + org-wide).", "operationId": "mcp-list_employee_mcp_connections", "security": [{"HTTPBearer": []}], "parameters": [{"name": "org_id", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid", "title": "Org Id"}}, {"name": "emp_id", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid", "title": "Emp Id"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": 