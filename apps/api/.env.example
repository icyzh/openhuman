# ─────────────────────────────────────────────────────────────────────
# OpenHuman API — Environment Variables
# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────

# Server
# API_HOST=0.0.0.0
# API_PORT=8000
# CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
# ENVIRONMENT=development

# Database (PostgreSQL via asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/openhuman
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# Auth (JWT)
# JWT_SECRET_KEY=change-me-in-production
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=60

# Encryption key for bot tokens (AES-256-GCM, 64 hex chars)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────────────────
# OpenAI — used by the LangGraph agent
# ─────────────────────────────────────────────────────────────────────

OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=               # unset for OpenAI; set for Azure / Ollama / etc.

# ─────────────────────────────────────────────────────────────────────
# Document storage
# ─────────────────────────────────────────────────────────────────────
# UPLOAD_DIR=./uploads

# ─────────────────────────────────────────────────────────────────────
# Bot Gateway (optional — set GATEWAY_ENABLED=true for Discord / Slack)
# ─────────────────────────────────────────────────────────────────────
# GATEWAY_ENABLED=false
# SLACK_APP_TOKEN=

# ─────────────────────────────────────────────────────────────────────
# Cognee (deferred — Phase 5)
# ─────────────────────────────────────────────────────────────────────
# COGNEE_DATA_DIR=./cognee_data
