{
  "$schema": "https://v2-8-17-canary-2.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "generate": {
      "dependsOn": ["@openhuman/api#generate:spec"],
      "outputs": ["src/api/**", "src/schemas/**"]
    },
    "generate:spec": {
      "outputs": ["openapi.json"]
    }
  }
}
